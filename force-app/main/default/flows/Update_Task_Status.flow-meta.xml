<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Screen Flow to update task status with validation. Checks checklist completion before allowing Completed status and requires blocked reason for Blocked status.</description>
    <interviewLabel>Update Task Status {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Task Status</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <status>Active</status>

    <!-- Input Variable -->
    <variables>
        <name>recordId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>

    <!-- Task record variable -->
    <variables>
        <name>varTaskRecord</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Task__c</objectType>
    </variables>

    <variables>
        <name>varTaskTitle</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>

    <variables>
        <name>varCurrentStatus</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>

    <variables>
        <name>varChecklistComplete</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>

    <variables>
        <name>varTaskProgress</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>2</scale>
    </variables>

    <!-- Start Element -->
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Get_Task_Record</targetReference>
        </connector>
    </start>

    <!-- Get Task Record -->
    <recordLookups>
        <name>Get_Task_Record</name>
        <label>Get Task Record</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <connector>
            <targetReference>Status_Update_Screen</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Task__c</object>
        <outputAssignments>
            <assignToReference>varTaskTitle</assignToReference>
            <field>Task_Title__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>varCurrentStatus</assignToReference>
            <field>Status__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>varChecklistComplete</assignToReference>
            <field>Checklist_Complete__c</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>varTaskProgress</assignToReference>
            <field>Task_Progress__c</field>
        </outputAssignments>
        <storeOutputAutomatically>false</storeOutputAutomatically>
    </recordLookups>

    <!-- Status Update Screen -->
    <screens>
        <name>Status_Update_Screen</name>
        <label>Update Task Status</label>
        <locationX>176</locationX>
        <locationY>278</locationY>
        <connector>
            <targetReference>Decision_Check_Status</targetReference>
        </connector>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>CurrentTaskInfo</name>
            <fieldText>&lt;p&gt;&lt;b&gt;Task:&lt;/b&gt; {!varTaskTitle}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Current Status:&lt;/b&gt; {!varCurrentStatus}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Progress:&lt;/b&gt; {!varTaskProgress}%&lt;/p&gt;&lt;p&gt;&lt;b&gt;Checklist Complete:&lt;/b&gt; {!varChecklistComplete}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>NewStatusPicklist</name>
            <choiceReferences>choiceNew</choiceReferences>
            <choiceReferences>choiceInProgress</choiceReferences>
            <choiceReferences>choiceBlocked</choiceReferences>
            <choiceReferences>choiceCompleted</choiceReferences>
            <dataType>String</dataType>
            <fieldText>New Status</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <fields>
            <name>BlockedReasonInput</name>
            <dataType>String</dataType>
            <fieldText>Blocked Reason</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <helpText>Required when setting status to Blocked</helpText>
            <isRequired>false</isRequired>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>NewStatusPicklist</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Blocked</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <!-- Choices for Status -->
    <choices>
        <name>choiceNew</name>
        <choiceText>New</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>New</stringValue>
        </value>
    </choices>
    <choices>
        <name>choiceInProgress</name>
        <choiceText>In Progress</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>In Progress</stringValue>
        </value>
    </choices>
    <choices>
        <name>choiceBlocked</name>
        <choiceText>Blocked</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Blocked</stringValue>
        </value>
    </choices>
    <choices>
        <name>choiceCompleted</name>
        <choiceText>Completed</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Completed</stringValue>
        </value>
    </choices>

    <!-- Decision: Check if Completed and Checklist not done -->
    <decisions>
        <name>Decision_Check_Status</name>
        <label>Check Status Selection</label>
        <locationX>176</locationX>
        <locationY>398</locationY>
        <defaultConnector>
            <targetReference>Update_Task_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Other Status</defaultConnectorLabel>
        <rules>
            <name>Is_Completed_No_Checklist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NewStatusPicklist</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varChecklistComplete</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Error_Screen_Checklist</targetReference>
            </connector>
            <label>Completed but Checklist Incomplete</label>
        </rules>
    </decisions>

    <!-- Error Screen: Checklist Not Complete -->
    <screens>
        <name>Error_Screen_Checklist</name>
        <label>Cannot Complete Task</label>
        <locationX>396</locationX>
        <locationY>518</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>ErrorMessage</name>
            <fieldText>&lt;p&gt;&lt;b style="color:red;"&gt;Cannot mark task as Completed&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;All checklist items must be completed before the task can be marked as Completed.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Please use the &lt;b&gt;Complete Checklist&lt;/b&gt; action to mark all items as done first, then try updating the status again.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <!-- Update Task Record -->
    <recordUpdates>
        <name>Update_Task_Record</name>
        <label>Update Task Record</label>
        <locationX>176</locationX>
        <locationY>518</locationY>
        <connector>
            <targetReference>Success_Screen</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <elementReference>NewStatusPicklist</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Blocked_Reason__c</field>
            <value>
                <elementReference>BlockedReasonInput</elementReference>
            </value>
        </inputAssignments>
        <object>Task__c</object>
    </recordUpdates>

    <!-- Success Screen -->
    <screens>
        <name>Success_Screen</name>
        <label>Status Updated</label>
        <locationX>176</locationX>
        <locationY>638</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>SuccessMessage</name>
            <fieldText>&lt;p&gt;&lt;b style="color:green;"&gt;Task Status Updated Successfully&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Task &lt;b&gt;{!varTaskTitle}&lt;/b&gt; status has been changed to &lt;b&gt;{!NewStatusPicklist}&lt;/b&gt;.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Click Finish to return to the task record.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
</Flow>
