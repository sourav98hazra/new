<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>End_Date_After_Start_Date</fullName>
    <active>true</active>
    <description>Ensures project end date is after start date</description>
    <errorConditionFormula>AND(
    NOT(ISBLANK(End_Date__c)),
    NOT(ISBLANK(Start_Date__c)),
    End_Date__c &lt;= Start_Date__c
)</errorConditionFormula>
    <errorDisplayField>End_Date__c</errorDisplayField>
    <errorMessage>Project end date must be after the start date.</errorMessage>
</ValidationRule>
